<nav class="navbar">
    <a href="/" class="navbar-brand">DevConnect</a>
    <div class="navbar-links">
        <a href="/explore" class="nav-link">Explore</a>
        <a href="/dashboard" class="nav-link">Dashboard</a>
        <a href="/post/create" class="nav-link">Write</a>
        
        <% if (typeof user !== 'undefined' && user) { %>
            <div style="display: flex; align-items: center; gap: 12px; margin-left: 12px; padding-left: 12px; border-left: 1px solid rgba(255,255,255,0.1);">
                <div class="avatar avatar-sm" style="background: linear-gradient(135deg, var(--amber), var(--coral));" title="<%= user.name %>">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
                <a href="/auth/logout" class="btn btn-secondary" style="padding: 6px 14px; font-size: 0.85rem;">Logout</a>
            </div>
        <% } else { %>
            <a href="/auth/login" class="nav-btn">Sign In</a>
        <% } %>
    </div>
</nav>