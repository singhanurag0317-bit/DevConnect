<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Your DevConnect dashboard — browse and share posts with the developer community.">
    <title>Dashboard — DevConnect</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <main class="flex-1">
        <div class="container">
            <div class="page-header animate-in">
                <h1 class="page-title gradient-text">Latest Posts</h1>
                <p class="page-subtitle">Welcome back, <strong><%= user.name %></strong> 👋</p>
            </div>

            <a href="/post/create" class="btn btn-primary animate-in animate-in-delay-1">✏️ Write a Post</a>

            <div style="margin-top: 28px;">
                <% if (posts.length === 0) { %>
                    <div class="empty-state glass animate-in animate-in-delay-2">
                        <p>No posts yet.</p>
                        <a href="/post/create">Write the first one! →</a>
                    </div>
                <% } else { %>
                    <% posts.forEach(post => { %>
                        <div class="post-card glass">
                            <span class="tag">Article</span>
                            <h2><a href="/post/<%= post._id %>"><%= post.title %></a></h2>
                            <div class="post-meta">
                                By <strong><%= post.author.name %></strong> &nbsp;•&nbsp;
                                <%= new Date(post.createdAt).toDateString() %>
                            </div>
                            <p class="post-excerpt"><%= post.content.substring(0, 160) %>...</p>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>