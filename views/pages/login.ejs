<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Sign in to DevConnect — the developer community platform.">
    <title>Login — DevConnect</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="auth-container">
        <div class="auth-box">
            <div style="text-align: center; margin-bottom: 24px;">
                <a href="/" style="font-weight: 900; font-size: 1.5rem; letter-spacing: -0.05em; color: var(--text-main);">DevConnect</a>
            </div>
            <h1>Authentication</h1>
            <p>Access your dashboard and the network.</p>

            <% if (error) { %>
                <div class="alert alert-error">Error: <%= error %></div>
            <% } %>

            <form action="/auth/login" method="POST">
                <div class="form-group">
                    <label class="form-label" for="email">Email Address</label>
                    <input type="email" id="email" name="email" class="form-input" placeholder="name@domain.com" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="password">Security Token</label>
                    <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required />
                </div>
                <button type="submit" class="btn btn-primary form-submit">Initialize Session</button>
            </form>

            <p style="text-align: center; margin-top: 32px; font-size: 0.9rem; color: var(--text-muted);">
                Unregistered? <a href="/auth/register" style="color: var(--text-main); font-weight: 600; text-decoration: underline;">Request Access</a>
            </p>
        </div>
    </div>
</body>
</html>