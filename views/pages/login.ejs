<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login — DevBlog</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { background:#0f0f23; color:white; font-family:Arial, sans-serif; display:flex; justify-content:center; align-items:center; min-height:100vh; }
        .card { background:#1a1a2e; padding:40px; border-radius:12px; width:100%; max-width:420px; }
        h2 { color:#e94560; margin-bottom:24px; text-align:center; }
        input { width:100%; padding:12px; margin-bottom:16px; background:#16213e; border:1px solid #333; border-radius:8px; color:white; font-size:1rem; }
        button { width:100%; padding:12px; background:#e94560; border:none; border-radius:8px; color:white; font-size:1rem; cursor:pointer; }
        button:hover { background:#c73652; }
        p { text-align:center; margin-top:16px; color:#888; }
        a { color:#e94560; }
        .error { background:#ff000022; border:1px solid #e94560; padding:10px; border-radius:8px; margin-bottom:16px; color:#e94560; text-align:center; }
    </style>
</head>
<body>
    <div class="card">
        <h2>Welcome Back</h2>

        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>

        <form action="/auth/login" method="POST">
            <input type="email" name="email" placeholder="Email" required />
            <input type="password" name="password" placeholder="Password" required />
            <button type="submit">Login</button>
        </form>

        <p>Don't have an account? <a href="/auth/register">Register</a></p>
    </div>
</body>
</html>