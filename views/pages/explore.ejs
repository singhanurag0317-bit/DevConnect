<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Explore DevConnect — Discover top articles and developers.">
    <title>Explore — DevConnect</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <main class="flex-1">
        <div class="container-narrow">
            <div class="page-header animate-in">
                <h1 class="page-title gradient-text-warm">Explore Community</h1>
                <p class="page-subtitle">Discover the latest articles from <%= totalUsers %> developers worldwide.</p>
            </div>

            <div style="margin-top: 12px;">
                <% if (posts.length === 0) { %>
                    <div class="empty-state glass animate-in animate-in-delay-1">
                        <p>No posts available yet.</p>
                    </div>
                <% } else { %>
                    <% posts.forEach((post, i) => { %>
                        <div class="post-card glass animate-in" style="animation-delay: <%= 0.1 * i %>s">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                <div>
                                    <span class="tag">Community</span>
                                    <h2><a href="/post/<%= post._id %>"><%= post.title %></a></h2>
                                </div>
                                <div class="avatar avatar-sm" style="background: linear-gradient(135deg, var(--emerald), var(--amber));" title="<%= post.author.name %>">
                                    <%= post.author.name.charAt(0).toUpperCase() %>
                                </div>
                            </div>
                            <div class="post-meta">
                                By <strong><%= post.author.name %></strong> &nbsp;•&nbsp;
                                <%= new Date(post.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) %>
                            </div>
                            <p class="post-excerpt"><%= post.content.substring(0, 200) %>...</p>
                            
                            <div style="margin-top: 16px; display: flex; align-items: center; gap: 12px;">
                                <form action="/post/<%= post._id %>/like" method="POST" style="display:inline;">
                                    <% const hasLiked = user && post.likes && post.likes.includes(user._id); %>
                                    <button type="submit" class="like-btn <%= hasLiked ? 'liked' : '' %>">
                                        <svg width="16" height="16" fill="<%= hasLiked ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                                        <%= post.likes ? post.likes.length : 0 %>
                                    </button>
                                </form>
                                <a href="/post/<%= post._id %>" class="btn btn-ghost" style="padding: 6px 12px; font-size: 0.85rem;">Read More →</a>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>
