<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="DevConnect — Where developers share ideas, write articles, and grow together. Join the community.">
    <title>DevConnect — Developer Community</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="navbar-wrapper">
        <%- include('../partials/navbar') %>
    </div>

    <main>
        <!-- ═══════════ HERO ═══════════ -->
        <section class="hero container">
            <div class="hero-content">
                <div class="section-header" style="margin-bottom: 24px;">
                    <span class="badge">v2.0 Beta</span>
                </div>
                <h1>Code. Share.<br><span class="text-accent">Iterate.</span></h1>
                <p>A minimalist, high-signal platform for engineers to document findings, share architectural decisions, and build reputation.</p>
                <div class="hero-actions">
                    <a href="/auth/register" class="btn btn-primary">Start Writing</a>
                    <a href="#features" class="btn btn-secondary">Explore Platform</a>
                </div>
            </div>
            
            <div class="hero-visual">
                <div class="bento-hero">
                    <div class="bento-box">
                        <div class="code-line w-full green"></div>
                        <div class="code-line w-half"></div>
                    </div>
                    <div class="bento-box"></div>
                    <div class="bento-box lg">
                        <div class="code-line w-full"></div>
                        <div class="code-line w-full"></div>
                        <div class="code-line w-half green"></div>
                    </div>
                    <div class="bento-box">
                        <div class="code-line w-half"></div>
                    </div>
                    <div class="bento-box"></div>
                    <div class="bento-box"></div>
                    <div class="bento-box"></div>
                </div>
            </div>
        </section>

        <!-- ═══════════ STATS BANNER ═══════════ -->
        <section class="container">
            <div class="stats-banner">
                <div class="stat-item">
                    <div class="stat-val" data-count="<%= stats.users %>"><%= stats.users %></div>
                    <div class="stat-lbl">Engineers</div>
                </div>
                <div class="stat-item">
                    <div class="stat-val" data-count="<%= stats.posts %>"><%= stats.posts %></div>
                    <div class="stat-lbl">Articles</div>
                </div>
                <div class="stat-item">
                    <div class="stat-val" data-count="<%= stats.likes %>"><%= stats.likes %></div>
                    <div class="stat-lbl">Insights Shared</div>
                </div>
            </div>
        </section>

        <!-- ═══════════ BENTO FEATURES ═══════════ -->
        <section class="section container" id="features">
            <div class="section-header text-center" style="text-align: center; display: flex; flex-direction: column; align-items: center;">
                <span class="badge">Architecture</span>
                <h2>Built for the <span class="text-accent">modern workflow</span>.</h2>
                <p>No distractions. Just a clean environment to document and discover.</p>
            </div>

            <div class="bento-grid">
                <!-- Large Feature 1 -->
                <div class="bento-card bento-span-2 bento-row-2">
                    <div class="bento-pattern-dots"></div>
                    <div class="icon">
                        <svg width="24" height="24" fill="none" stroke="var(--text-main)" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    </div>
                    <h3 class="mt-8">Distraction-Free Editor</h3>
                    <p>A pristine canvas designed strictly for content. Support for markdown syntax, code blocks, and fast publishing without the bloat of traditional WYSIWYG editors.</p>
                </div>

                <!-- Small Feature -->
                <div class="bento-card">
                    <div class="icon">
                        <svg width="24" height="24" fill="none" stroke="var(--accent-green)" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <h3>Developer Community</h3>
                    <p>Connect with peers, share repositories, and discuss system designs.</p>
                </div>

                <!-- Small Feature -->
                <div class="bento-card">
                    <div class="icon">
                        <svg width="24" height="24" fill="none" stroke="var(--text-main)" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                    </div>
                    <h3>Command Dashboard</h3>
                    <p>Track metrics, manage drafts, and organize your technical knowledge base.</p>
                </div>

                <!-- Medium Feature -->
                <div class="bento-card bento-span-2">
                    <div class="bento-pattern-graph"></div>
                    <div class="icon">
                        <svg width="24" height="24" fill="none" stroke="var(--accent-green)" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    </div>
                    <h3>High Signal, Low Noise</h3>
                    <p>The feed algorithm strictly prioritizes technical depth and peer appreciation over clickbait.</p>
                </div>
            </div>
        </section>

        <!-- ═══════════ TESTIMONIALS / QUOTES ═══════════ -->
        <section class="section container">
            <div class="section-header">
                <span class="badge">Feedback</span>
                <h2>What engineers are saying.</h2>
            </div>
            
            <div class="bento-grid" style="grid-auto-rows: auto;">
                <div class="card">
                    <p style="font-size: 1.1rem; margin-bottom: 24px; color: var(--text-main);">"DevConnect strips away the fluff. It’s like a minimalist GitHub for blogging. The typography is perfect."</p>
                    <div class="flex-between">
                        <div>
                            <strong style="display: block;">Aarav Patel</strong>
                            <span style="font-size: 0.85rem; color: var(--text-muted); font-family: 'JetBrains Mono';">Full-Stack Dev</span>
                        </div>
                        <div class="avatar">A</div>
                    </div>
                </div>
                <div class="card">
                    <p style="font-size: 1.1rem; margin-bottom: 24px; color: var(--text-main);">"I used to write on Medium, but it felt too commercial. This feels like it was actually built by an engineer, for engineers."</p>
                    <div class="flex-between">
                        <div>
                            <strong style="display: block;">Sophia Chen</strong>
                            <span style="font-size: 0.85rem; color: var(--text-muted); font-family: 'JetBrains Mono';">Frontend Eng</span>
                        </div>
                        <div class="avatar">S</div>
                    </div>
                </div>
                <div class="card" style="grid-column: span 2;">
                    <p style="font-size: 1.25rem; font-weight: 500; margin-bottom: 24px; color: var(--text-main);">"The light theme with the graph paper background is incredibly nostalgic and clean. It puts the focus entirely on the code and the content. Hands down the best developer blogging platform right now."</p>
                    <div class="flex-between">
                        <div>
                            <strong style="display: block;">Marcus Rivera</strong>
                            <span style="font-size: 0.85rem; color: var(--text-muted); font-family: 'JetBrains Mono';">DevOps Engineer</span>
                        </div>
                        <div class="avatar avatar-md" style="width: 48px; height: 48px;">M</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══════════ CTA ═══════════ -->
        <section class="section container" style="padding-bottom: 160px; text-align: center;">
            <div class="card" style="padding: 80px 40px; background: var(--bg-surface);">
                <h2 style="font-size: 2.5rem; margin-bottom: 16px;">Ready to publish?</h2>
                <p style="font-size: 1.2rem; margin-bottom: 32px; max-width: 500px; margin-left: auto; margin-right: auto;">Join the platform where serious developers document their work.</p>
                <a href="/auth/register" class="btn btn-primary" style="font-size: 1.1rem; padding: 16px 32px;">Create Account</a>
            </div>
        </section>

    </main>

    <%- include('../partials/footer') %>
</body>
</html>
