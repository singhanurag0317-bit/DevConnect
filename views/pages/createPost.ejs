<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Write and share a new post on DevConnect.">
    <title>Write a Post — DevConnect</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <main class="flex-1">
        <div class="container-narrow" style="padding-top: 48px; padding-bottom: 48px;">
            <div class="page-header animate-in">
                <h1 class="page-title gradient-text-warm">Write a Post</h1>
                <p class="page-subtitle">Share your knowledge with the DevConnect community</p>
            </div>

            <div class="form-card glass animate-in animate-in-delay-1">
                <% if (error) { %>
                    <div class="alert alert-error">⚠️ <%= error %></div>
                <% } %>

                <form action="/post/create" method="POST">
                    <div class="input-group">
                        <label for="title" class="form-label">Post Title</label>
                        <input type="text" id="title" name="title" class="input" placeholder="Give your post a great title..." required />
                    </div>

                    <div class="input-group">
                        <label for="content" class="form-label">Content</label>
                        <textarea id="content" name="content" class="input" style="height: 320px;" placeholder="Write your post here..."></textarea>
                    </div>

                    <div style="display:flex; gap:14px; align-items:center;">
                        <button type="submit" class="btn btn-primary">🚀 Publish Post</button>
                        <a href="/dashboard" class="btn btn-ghost">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>