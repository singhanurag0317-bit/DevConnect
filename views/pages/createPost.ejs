<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Write and share a new post on DevConnect.">
    <title>Write a Post — DevConnect</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <main class="flex-1">
        <div class="container-wide" style="padding-top: 48px; padding-bottom: 48px;">
            <div class="page-header animate-in">
                <h1 class="page-title gradient-text-warm">Craft Your Story</h1>
                <p class="page-subtitle">Share your knowledge with the DevConnect community</p>
            </div>

            <div class="write-layout">
                <!-- Editor Main Area -->
                <div class="form-card glass animate-in animate-in-delay-1">
                    <% if (error) { %>
                        <div class="alert alert-error">⚠️ <%= error %></div>
                    <% } %>

                    <form action="/post/create" method="POST" id="postForm">
                        <div class="input-group">
                            <label for="title" class="form-label">Post Title</label>
                            <input type="text" id="title" name="title" class="input" style="font-size: 1.5rem; padding: 16px 20px;" placeholder="e.g. Building a REST API with Node.js..." required />
                        </div>

                        <div class="input-group">
                            <label for="content" class="form-label">Content (Supports Markdown Format)</label>
                            <div class="editor-toolbar">
                                <button type="button" class="toolbar-btn" title="Bold"><b>B</b></button>
                                <button type="button" class="toolbar-btn" title="Italic"><i>I</i></button>
                                <button type="button" class="toolbar-btn" title="Code"><code>&lt;/&gt;</code></button>
                                <button type="button" class="toolbar-btn" title="Link">🔗</button>
                            </div>
                            <textarea id="content" name="content" class="input" style="height: 400px; font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; border-top-left-radius: 0; border-top-right-radius: 0;" placeholder="Start writing your amazing post here..."></textarea>
                        </div>

                        <div style="display:flex; justify-content: space-between; align-items:center;">
                            <div style="display:flex; gap:14px; align-items:center;">
                                <button type="submit" class="btn btn-primary">🚀 Publish Post</button>
                                <a href="/dashboard" class="btn btn-ghost">Cancel</a>
                            </div>
                            <div style="color: var(--text-muted); font-size: 0.85rem;" id="wordCount">0 words</div>
                        </div>
                    </form>
                </div>

                <!-- Writing Tips Sidebar -->
                <aside class="animate-in animate-in-delay-2">
                    <div class="glass widget">
                        <h3 class="widget-title">💡 Writing Guidelines</h3>
                        <div style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;">
                            <p style="margin-bottom: 16px;">Make your post stand out in the community:</p>
                            
                            <strong style="color: var(--amber); display: block; margin-bottom: 4px;">1. Catchy Title</strong>
                            <p style="margin-bottom: 12px; font-size: 0.85rem;">A clear, concise title helps readers understand what to expect.</p>
                            
                            <strong style="color: var(--emerald); display: block; margin-bottom: 4px;">2. Value First</strong>
                            <p style="margin-bottom: 12px; font-size: 0.85rem;">Start with the problem you're solving or the insight you're sharing.</p>
                            
                            <strong style="color: var(--coral); display: block; margin-bottom: 4px;">3. Code Formatting</strong>
                            <p style="font-size: 0.85rem;">If you're sharing code, make sure it's readable and properly spaced.</p>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script>
        // Simple word counter
        document.getElementById('content').addEventListener('input', function(e) {
            const text = e.target.value.trim();
            const words = text ? text.split(/\s+/).length : 0;
            document.getElementById('wordCount').textContent = words + (words === 1 ? ' word' : ' words');
        });
    </script>
</body>
</html>