<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Write and share a new post on DevConnect.">
    <title>Write a Post — DevConnect</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="navbar-wrapper">
        <%- include('../partials/navbar') %>
    </div>

    <main class="flex-1" style="padding-top: 40px; padding-bottom: 100px;">
        <div class="container-wide">
            
            <div class="section-header" style="margin-bottom: 32px;">
                <span class="badge">Editor</span>
                <h1 style="font-size: 2.5rem; margin-bottom: 8px;">Draft New Document</h1>
                <p style="font-size: 1.1rem; color: var(--text-muted);">Format using Markdown. Code blocks are fully supported.</p>
            </div>

            <div class="write-layout">
                <!-- Editor Main Area -->
                <div>
                    <% if (error) { %>
                        <div class="alert alert-error">Error: <%= error %></div>
                    <% } %>

                    <form action="/post/create" method="POST" id="postForm" class="card" style="padding: 40px;">
                        <div class="form-group">
                            <label for="title" class="form-label" style="font-size: 0.95rem;">Document Title</label>
                            <input type="text" id="title" name="title" class="form-input" style="font-size: 1.5rem; padding: 16px; font-weight: 700; border-radius: 8px;" placeholder="e.g. System Architecture for V2..." required />
                        </div>

                        <div class="form-group" style="margin-bottom: 32px;">
                            <label for="content" class="form-label" style="font-size: 0.95rem;">Content Buffer</label>
                            <div style="border: 1px solid var(--border-bold); border-bottom: none; padding: 8px 12px; background: var(--bg-surface); border-radius: 8px 8px 0 0; display: flex; gap: 8px;">
                                <button type="button" class="btn btn-outline" style="padding: 4px 12px; border: none; font-size: 0.85rem;" title="Bold"><b>B</b></button>
                                <button type="button" class="btn btn-outline" style="padding: 4px 12px; border: none; font-size: 0.85rem;" title="Italic"><i>I</i></button>
                                <button type="button" class="btn btn-outline" style="padding: 4px 12px; border: none; font-family: monospace; font-size: 0.85rem;" title="Code">&lt;/&gt;</button>
                            </div>
                            <textarea id="content" name="content" class="form-input" style="height: 450px; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; line-height: 1.6; border-radius: 0 0 8px 8px; resize: vertical;" placeholder="Initialize document body here..."></textarea>
                        </div>

                        <div style="display:flex; justify-content: space-between; align-items:center; border-top: 1px solid var(--border-light); padding-top: 24px;">
                            <div style="display:flex; gap:16px; align-items:center;">
                                <button type="submit" class="btn btn-primary">Commit Document</button>
                                <a href="/dashboard" class="btn btn-outline">Discard Draft</a>
                            </div>
                            <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: var(--text-muted);" id="wordCount">Word Count: 0</div>
                        </div>
                    </form>
                </div>

                <!-- Writing Tips Sidebar -->
                <aside>
                    <div class="card" style="position: sticky; top: 120px;">
                        <h3 style="font-size: 1.1rem; margin-bottom: 24px; border-bottom: 1px solid var(--border-light); padding-bottom: 16px;">Publishing Intel</h3>
                        <div style="color: var(--text-main); font-size: 0.9rem; line-height: 1.6; display: flex; flex-direction: column; gap: 20px;">
                            
                            <div>
                                <strong style="color: var(--accent-green); display: block; margin-bottom: 4px;">// 01. Naming Convention</strong>
                                <p style="color: var(--text-muted);">Ensure the title reflects the exact technical domain or problem solved.</p>
                            </div>
                            
                            <div>
                                <strong style="color: var(--accent-gold); display: block; margin-bottom: 4px;">// 02. Structure & Hierarchy</strong>
                                <p style="color: var(--text-muted);">Use markdown headings (##) to divide complex systems into digestible blocks.</p>
                            </div>
                            
                            <div>
                                <strong style="color: var(--text-main); display: block; margin-bottom: 4px;">// 03. Code Blocks</strong>
                                <p style="color: var(--text-muted);">Surround code with triple backticks (```) for accurate syntax rendering.</p>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script>
        // Simple word counter
        document.getElementById('content').addEventListener('input', function(e) {
            const text = e.target.value.trim();
            const words = text ? text.split(/\s+/).length : 0;
            document.getElementById('wordCount').textContent = 'Word Count: ' + words;
        });
    </script>
</body>
</html>