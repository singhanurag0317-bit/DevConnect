<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register — DevConnect</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        html, body { height:100%; }
        body {
            background:#0a0a0a;
            color:#e0e0e0;
            font-family:'Inter', sans-serif;
            display:flex;
            flex-direction:column;
            min-height:100vh;
            justify-content:center;
            align-items:center;
        }
        .brand {
            font-size:1.8rem;
            font-weight:800;
            background:linear-gradient(90deg,#d4a017,#2e8b57);
            -webkit-background-clip:text;
            -webkit-text-fill-color:transparent;
            margin-bottom:28px;
            letter-spacing:-0.5px;
        }
        .card {
            background:linear-gradient(135deg,#111111 0%,#1a1a1a 100%);
            padding:44px 40px;
            border-radius:18px;
            width:100%;
            max-width:440px;
            border:1px solid #2a2a2a;
            box-shadow:0 8px 48px #0008;
        }
        h2 {
            color:#e8e8e8;
            margin-bottom:8px;
            text-align:center;
            font-size:1.5rem;
            font-weight:700;
        }
        .sub {
            text-align:center;
            color:#707070;
            font-size:0.88rem;
            margin-bottom:28px;
        }
        input {
            width:100%;
            padding:13px 16px;
            margin-bottom:14px;
            background:#0e0e0e;
            border:1.5px solid #2a2a2a;
            border-radius:10px;
            color:#e0e0e0;
            font-size:0.97rem;
            font-family:'Inter', sans-serif;
            transition:border-color 0.2s, box-shadow 0.2s;
            outline:none;
        }
        input:focus { border-color:#d4a017; box-shadow:0 0 0 3px #d4a01722; }
        input::placeholder { color:#4a4a4a; }
        button {
            width:100%;
            padding:13px;
            background:linear-gradient(135deg,#d4a017,#2e8b57);
            border:none;
            border-radius:10px;
            color:white;
            font-size:1rem;
            font-weight:700;
            font-family:'Inter', sans-serif;
            cursor:pointer;
            box-shadow:0 4px 18px #d4a01733;
            transition:opacity 0.2s, transform 0.15s;
            margin-top:4px;
        }
        button:hover { opacity:0.88; transform:translateY(-1px); }
        p { text-align:center; margin-top:18px; color:#606060; font-size:0.9rem; }
        a { color:#2e8b57; text-decoration:none; font-weight:600; }
        a:hover { color:#d4a017; }
        .error {
            background:#1e1a0a;
            border:1.5px solid #d4a01788;
            padding:11px 14px;
            border-radius:10px;
            margin-bottom:16px;
            color:#d4a017;
            text-align:center;
            font-size:0.9rem;
        }
        .divider { border:none; border-top:1px solid #2a2a2a; margin:20px 0; }
        .hint { color:#4a4a4a; font-size:0.78rem; margin-top:-8px; margin-bottom:14px; padding-left:4px; }
    </style>
</head>
<body>
    <div class="brand">DevConnect</div>
    <div class="card">
        <h2>Create Account</h2>
        <p class="sub">Join the developer community</p>
        <hr class="divider">

        <% if (error) { %>
            <div class="error">⚠️ <%= error %></div>
        <% } %>

        <form action="/auth/register" method="POST">
            <input type="text"     name="name"     placeholder="Full Name" required />
            <input type="email"    name="email"    placeholder="Email address" required />
            <input type="password" name="password" placeholder="Password" required />
            <p class="hint">Minimum 6 characters</p>
            <button type="submit">Create Account</button>
        </form>

        <p>Already have an account? <a href="/auth/login">Sign in</a></p>
    </div>
</body>
</html>