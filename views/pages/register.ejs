<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Create your DevConnect account and join the developer community.">
    <title>Register — DevConnect</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="auth-container">
        <div class="auth-box">
            <div style="text-align: center; margin-bottom: 24px;">
                <a href="/" style="font-weight: 900; font-size: 1.5rem; letter-spacing: -0.05em; color: var(--text-main);">DevConnect</a>
            </div>
            <h1>Initialize Node</h1>
            <p>Join the engineering network.</p>

            <% if (error) { %>
                <div class="alert alert-error">Error: <%= error %></div>
            <% } %>

            <form action="/auth/register" method="POST">
                <div class="form-group">
                    <label class="form-label" for="name">Developer Alias</label>
                    <input type="text" id="name" name="name" class="form-input" placeholder="Full Name" required />
                </div>
                <div class="form-group">
                    <label class="form-label" for="email">Email Address</label>
                    <input type="email" id="email" name="email" class="form-input" placeholder="name@domain.com" required />
                </div>
                <div class="form-group" style="margin-bottom: 8px;">
                    <label class="form-label" for="password">Security Token</label>
                    <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required />
                </div>
                <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 24px; font-family: 'JetBrains Mono', monospace;">Min. 6 characters required.</p>
                
                <button type="submit" class="btn btn-primary form-submit">Deploy Node</button>
            </form>

            <p style="text-align: center; margin-top: 32px; font-size: 0.9rem; color: var(--text-muted);">
                Already registered? <a href="/auth/login" style="color: var(--text-main); font-weight: 600; text-decoration: underline;">Authenticate</a>
            </p>
        </div>
    </div>
</body>
</html>